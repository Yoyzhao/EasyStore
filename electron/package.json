{
  "name": "easystore-electron",
  "version": "1.0.0",
  "description": "EasyStore Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.easystore.app",
    "productName": "EasyStore",
    "directories": {
      "output": "release_final"
    },
    "win": {
      "icon": "icon.ico",
      "target": [
        "portable",
        "zip"
      ]
    },
    "files": [
      "main.js",
      "package.json",
      "icon.ico",
      "web/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../server/dist/easystore-server",
        "to": "bin/easystore-server"
      }
    ]
  },
  "dependencies": {
    "axios": "^1.6.2",
    "portfinder": "^1.0.32"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  }
}
